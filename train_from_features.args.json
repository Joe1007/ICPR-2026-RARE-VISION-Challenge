{
  "features_dir": "features",
  "model": "linear",
  "hidden_dim": 256,
  "dropout": 0.3,
  "epochs": 50,
  "batch_size": 256,
  "lr": 0.001,
  "weight_decay": 0.0001,
  "seed": 42,
  "loss": "bce",
  "focal_alpha": 0.25,
  "focal_gamma": 2.0,
  "asl_gamma_neg": 4.0,
  "asl_gamma_pos": 1.0,
  "weighted_sampling": false,
  "smooth_window": 5,
  "threshold": 0.5,
  "find_best_threshold": true,
  "out_pred_json": "val_pred.json",
  "out_gt_json": "val_gt.json",
  "metrics_json": "val_metrics.json",
  "save_model": "classifier.pth"
}